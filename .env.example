# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Supabase (Postgres) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Secret key is used server-side only (API routes). You'll also need the
# publishable key on the client once the booking page is wired up to
# Stripe Elements (see README.md).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend (email) ---
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=quotes@royalrollers.example
OWNER_ALERT_EMAIL=owner@royalrollers.example

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://royalrollers.example

# --- Business rules ---
# Percentage of the total quote charged as a deposit at booking.
DEPOSIT_PERCENT=25

# --- Business rules: instant-estimate pricing (placeholder figures) ---
# Same status DEPOSIT_PERCENT had before that got decided -- these are
# scaffolded placeholders, not a real pricing decision. Non-binding: the
# real price is always set manually via PATCH /api/quote/[id]/price.
# No API key needed for the distance lookup itself -- see
# app/api/route-distance/route.ts (free ZIP geocoding, no signup).
ESTIMATE_BASE_FEE_CENTS=15000
ESTIMATE_PER_MILE_CENTS=85
ESTIMATE_ENCLOSED_SURCHARGE_PERCENT=30
ESTIMATE_PERSONAL_DRIVER_SURCHARGE_PERCENT=20
ESTIMATE_NOT_RUNNING_FLAT_ADD_CENTS=20000
ESTIMATE_RANGE_SPREAD_PERCENT=15

# --- Internal ops ---
# Shared secret for the stopgap /api/charge-balance route until a real
# trigger (admin UI, cron, webhook) replaces it. Generate a long random
# string, e.g. `openssl rand -hex 32`.
INTERNAL_OPS_SECRET=
